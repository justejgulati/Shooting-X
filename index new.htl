<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Defense Prototype</title>
    <style>
        :root {
            --bg-color: #121214;
            --container-bg: #1a1a1e;
            --accent-color: #ffb703;
            --text-color: #ffffff;
            --green-bar: #38b000;
            --blue-bar: #00b4d8;
        }

        body {
            margin: 0;
            padding: 20px;
            background-color: var(--bg-color);
            font-family: 'Courier New', Courier, monospace;
            color: var(--text-color);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h1 {
            margin-bottom: 5px;
            text-shadow: 2px 2px #000;
            color: var(--accent-color);
        }

        p.subtitle {
            margin: 0 0 20px 0;
            color: #aaa;
            font-size: 14px;
        }

        /* --- UI STATUS BARS --- */
        .status-container {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            background: #24242b;
            padding: 15px;
            border-radius: 8px;
            border: 2px solid var(--accent-color);
            width: 100%;
            max-width: 800px;
            box-sizing: border-box;
        }

        .status-box {
            flex: 1;
            text-align: center;
        }

        .bar-label {
            font-weight: bold;
            margin-bottom: 5px;
            display: block;
            font-size: 13px;
        }

        .bar-outer {
            width: 100%;
            background-color: #333;
            height: 20px;
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid #555;
        }

        .bar-inner {
            height: 100%;
            width: 100%;
            transition: width 0.3s ease;
        }

        #health-bar { background-color: var(--green-bar); }
        #weapon-bar { background-color: var(--blue-bar); width: 25%; }

        /* --- GAME ARENA LAYOUT --- */
        .game-wrapper {
            display: flex;
            gap: 20px;
            width: 100%;
            max-width: 800px;
        }

        .game-arena {
            flex: 2;
            height: 440px;
            background-color: var(--container-bg);
            border: 3px solid #fff;
            border-radius: 8px;
            position: relative;
            padding: 15px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
        }

        /* Robber Combat Zone Inside Arena */
        .combat-zone {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            background: #0f0f12;
            border-radius: 6px;
            margin-bottom: 10px;
            border: 1px solid #333;
        }

        .robber-sprite {
            font-size: 50px;
            cursor: pointer;
            transition: transform 0.1s ease, opacity 0.5s ease;
            user-select: none;
            position: relative;
        }

        .robber-sprite.hit {
            transform: scale(1.3) rotate(15deg);
        }

        .robber-sprite.dead {
            transform: rotate(90deg) translateY(20px);
            opacity: 0.3;
            pointer-events: none;
        }

        .hp-text {
            font-size: 12px;
            color: #ff4d5a;
            margin-top: 5px;
            font-weight: bold;
        }

        .artwork-slot {
            flex: 1;
            height: 440px;
            background-color: #111;
            border: 3px dashed var(--accent-color);
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        .artwork-slot img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        /* --- SHOP SCREEN & ACTION CONTROLS --- */
        .game-actions {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 10px;
        }

        .shop-screen {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid #444;
            padding: 10px;
            border-radius: 6px;
            text-align: center;
        }

        .btn {
            background-color: var(--accent-color);
            color: black;
            border: none;
            padding: 10px 20px;
            font-size: 14px;
            font-family: inherit;
            cursor: pointer;
            border-radius: 4px;
            font-weight: bold;
            box-shadow: 0 4px #b58105;
        }

        .btn:hover { background-color: #ffd000; }
        .btn:active {
            box-shadow: 0 2px #b58105;
            transform: translateY(2px);
        }
        .btn:disabled {
            background-color: #444;
            color: #888;
            box-shadow: none;
            cursor: not-allowed;
        }

        .btn-shoot {
            background-color: #e63946;
            color: white;
            box-shadow: 0 4px #9b1c26;
        }
        .btn-shoot:hover { background-color: #ff4d5a; }
        .btn-shoot:active { box-shadow: 0 2px #9b1c26; }

        .dev-panel {
            margin-top: 20px;
            background: #222;
            padding: 10px;
            border-radius: 5px;
            font-size: 12px;
        }
    </style>
</head>
<body>

    <h1>🚨 BANK DEFENSE 🚨</h1>
    <p class="subtitle">Shoot robbers, gain coins, and upgrade your guns!</p>

    <!-- UI STATUS BARS -->
    <div class="status-container">
        <div class="status-box">
            <span class="bar-label">COINS: <span id="coin-count">0</span></span>
            <div style="font-size: 24px; font-weight: bold; margin-top: 5px;">🪙</div>
        </div>
        <div class="status-box">
            <span class="bar-label">HP (HEALTH)</span>
            <div class="bar-outer">
                <div id="health-bar" class="bar-inner"></div>
            </div>
        </div>
        <div class="status-box">
            <span class="bar-label">WEAPON TIER: <span id="weapon-tier-text">Pistol (Tier 1)</span></span>
            <div class="bar-outer">
                <div id="weapon-bar" class="bar-inner"></div>
            </div>
        </div>
    </div>

    <!-- MAIN GAME AREA -->
    <div class="game-wrapper">
        <!-- Game Arena Container -->
        <div class="game-arena" id="game-arena">
            
            <!-- Combat Graphic Zone -->
            <div class="combat-zone">
                <div id="robber-target" class="robber-sprite" onclick="shootRobber()">🥷</div>
                <div id="robber-hp" class="hp-text">ROBBER HP: 30/30</div>
            </div>
            
            <!-- Gameplay Interactive Button -->
            <div class="game-actions">
                <button class="btn btn-shoot" id="shoot-btn" onclick="shootRobber()">💥 Pull Trigger</button>
            </div>
            
            <!-- Shop Upgrade Screen Context UI -->
            <div class="shop-screen">
                <button class="btn" id="upgrade-weapon-btn" onclick="upgradeWeapon()">Upgrade to Assault Rifle (50 Coins)</button>
                <p id="shop-message" style="color: #ffb703; margin: 5px 0 0 0; min-height: 18px; font-size: 13px;"></p>
            </div>

            <div style="text-align: center; font-size: 11px; color: #888;">Combat Feed: <span id="system-log">A robber has entered the bank! Shoot him!</span></div>
        </div>

        <!-- Visual Artwork Slot -->
        <div class="artwork-slot">
            <img id="artwork-display" src="" alt="Current Gun Asset">
        </div>
    </div>

    <!-- QA/Dev Quick Cheat Panel -->
    <div class="dev-panel">
        <strong>QA Tools:</strong> 
        <button onclick="modifyCoins(50)">+50 Coins</button>
        <button onclick="resetDemo()">Reset Data</button>
    </div>

    <script>
        /* ==========================================================================
           INVENTORY, LEVEL & STATE MANAGEMENT
           ========================================================================== */
        const gameState = {
            coins: 0,
            health: 100,
            weaponTier: 1, 
            inventory: {
                currentWeapon: "Pistol",
                upgradesPurchased: []
            }
        };

        // Enemy State Tracking
        const enemyState = {
            hp: 30,
            maxHp: 30,
            isDead: false
        };

        // UI Gun Vector Displays (Encoded SVGs for standalone operation)
        const GUN_ARTWORK = {
            pistol: "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200' viewBox='0 0 100 100'><rect width='100' height='100' fill='%231a1a1e'/><path d='M30,40 L65,40 L65,50 L50,50 L45,75 L35,75 Z' fill='%23777' stroke='%23fff' stroke-width='2'/><text x='50%' y='25%' dominant-baseline='middle' text-anchor='middle' fill='%23aaa' font-family='monospace' font-size='9'>TIER 1: PISTOL</text></svg>",
            rifle: "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200' viewBox='0 0 100 100'><rect width='100' height='100' fill='%231a1a1e'/><path d='M20,40 L80,42 L80,48 L65,52 L55,52 L50,68 L42,68 L45,52 L30,52 L25,65 L18,65 Z' fill='%23444' stroke='%23ffb703' stroke-width='2'/><text x='50%' y='25%' dominant-baseline='middle' text-anchor='middle' fill='%23ffb703' font-family='monospace' font-size='9'>TIER 2: RIFLE</text></svg>"
        };

        /**
         * Updates all frontend tracking DOM elements to reflect current status levels
         */
        function updateUI() {
            // Update Coin Displays
            document.getElementById('coin-count').innerText = gameState.coins;
            document.getElementById('health-bar').style.width = gameState.health + '%';
            
            const weaponBar = document.getElementById('weapon-bar');
            const weaponText = document.getElementById('weapon-tier-text');
            const upgradeBtn = document.getElementById('upgrade-weapon-btn');
            const artworkImg = document.getElementById('artwork-display');

            // Handle Weapon Upgrades Visual Tracking
            if (gameState.weaponTier === 1) {
                weaponBar.style.width = '35%';
                weaponText.innerText = "Pistol (Tier 1)";
                artworkImg.src = GUN_ARTWORK.pistol;
                
                if (gameState.coins < 50) {
                    upgradeBtn.disabled = true;
                    upgradeBtn.innerText = "Need 50 Coins for Upgrade";
                } else {
                    upgradeBtn.disabled = false;
                    upgradeBtn.innerText = "Upgrade to Assault Rifle (50 Coins)";
                }
            } else {
                weaponBar.style.width = '100%';
                weaponText.innerText = "Assault Rifle (MAX TIER)";
                artworkImg.src = GUN_ARTWORK.rifle;
                upgradeBtn.disabled = true;
                upgradeBtn.innerText = "Fully Upgraded!";
            }

            // Update Robber Display
            const robberElement = document.getElementById('robber-target');
            const robberHpText = document.getElementById('robber-hp');
            const shootBtn = document.getElementById('shoot-btn');

            if (enemyState.isDead) {
                robberElement.className = "robber-sprite dead";
                robberElement.innerText = "💀";
                robberHpText.innerText = "DEAD (Gained Coins!)";
                shootBtn.innerText = "🔄 Call Next Robber";
            } else {
                robberElement.className = "robber-sprite";
                robberElement.innerText = "🥷";
                robberHpText.innerText = `ROBBER HP: ${enemyState.hp}/${enemyState.maxHp}`;
                shootBtn.innerText = "💥 Pull Trigger";
            }
        }

        /**
         * Core Mechanics: Gaining coins by actively neutralizing robbers
         */
        function shootRobber() {
            const logMsg = document.getElementById('system-log');
            const robberElement = document.getElementById('robber-target');

            // If robber is already dead, clicking resets/spawns a new one
            if (enemyState.isDead) {
                respawnRobber();
                return;
            }

            // Calculate damage based on Weapon Tier
            const damage = gameState.weaponTier === 2 ? 15 : 10;
            enemyState.hp = Math.max(0, enemyState.hp - damage);

            // Trigger visual hit animation kickback
            robberElement.classList.add('hit');
            setTimeout(() => robberElement.classList.remove('hit'), 100);

            logMsg.innerText = `Shot fired! Dealt ${damage} damage to the robber.`;

            // Check if shot killed the robber
            if (enemyState.hp <= 0) {
                enemyState.isDead = true;
                
                // Reward coins upon kill
                const coinReward = gameState.weaponTier === 2 ? 30 : 15;
                gameState.coins += coinReward;
                logMsg.innerText = `Target neutralized! Dropped +${coinReward} coins.`;
            }

            updateUI();
        }

        function respawnRobber() {
            enemyState.hp = 30;
            enemyState.isDead = false;
            document.getElementById('system-log').innerText = "Another robber runs into the lobby! Open fire!";
            updateUI();
        }

        /**
         * Core Mechanics: Upgrading via the custom shop screen
         */
        function upgradeWeapon() {
            const cost = 50;
            const shopMsg = document.getElementById('shop-message');
            const logMsg = document.getElementById('system-log');

            if (gameState.weaponTier >= 2) return;

            if (gameState.coins >= cost) {
                gameState.coins -= cost;
                gameState.weaponTier = 2;
                gameState.inventory.currentWeapon = "Assault Rifle";
                gameState.inventory.upgradesPurchased.push("Rifle_Tier_2");

                shopMsg.style.color = "#38b000";
                shopMsg.innerText = "Rifle Upgraded! Shred through targets now.";
                logMsg.innerText = "Upgraded to Assault Rifle! High velocity damage unlocked.";
                
                updateUI();
            } else {
                shopMsg.style.color = "#e63946";
                shopMsg.innerText = "Not enough coins! Eliminate more robbers.";
            }
        }

        /* ==========================================================================
           QA ENGINE TESTING & UTILITY PROCEDURES
           ========================================================================== */
        function modifyCoins(amount) {
            gameState.coins = Math.max(0, gameState.coins + amount);
            document.getElementById('system-log').innerText = `QA Modification: Adjusted coins by ${amount}.`;
            updateUI();
        }

        function resetDemo() {
            gameState.coins = 0;
            gameState.health = 100;
            gameState.weaponTier = 1;
            gameState.inventory.currentWeapon = "Pistol";
            gameState.inventory.upgradesPurchased = [];
            respawnRobber();
        }

        window.onload = () => {
            updateUI();
        };
    </script>
</body>
</html>